# POKE_API_KEY: Required for OpenAI-compatible calls to the Poke API.
# AI Studio automatically injects this at runtime from user secrets.
POKE_API_KEY="MY_POKE_API_KEY"

# POKE_API_BASE_URL: The OpenAI-compatible base URL for the Poke API.
POKE_API_BASE_URL="https://api.poke.com/v1"

# POKE_MODEL: The model name to use for summaries and digest generation.
POKE_MODEL="gpt-4o-mini"

# NEWS_API_KEY: Required for live news fetching from NewsAPI.
NEWS_API_KEY="MY_NEWS_API_KEY"

# NEWS_API_BASE_URL: Base URL for the news provider.
NEWS_API_BASE_URL="https://newsapi.org/v2"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
